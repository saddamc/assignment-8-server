model User {
    id                 String     @id @default(uuid())
    name               String?
    email              String     @unique
    password           String
    role               UserRole   @default(CUSTOMER)
    profileImage       String?
    status             UserStatus @default(ACTIVE)
    needPasswordChange Boolean    @default(false)
    createdAt          DateTime   @default(now())
    updatedAt          DateTime   @updatedAt

    admin               Admin?
    seller              Seller?
    customer            Customer?
    passwordResetTokens PasswordResetToken[]

    @@map("users")
}

model PasswordResetToken {
    id        String   @id @default(uuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id])
    token     String   @unique
    expiresAt DateTime
    used      Boolean  @default(false)
    createdAt DateTime @default(now())

    @@map("password_reset_tokens")
}

model Admin {
    id            String   @id @default(uuid())
    name          String
    email         String   @unique
    profilePhoto  String?
    contactNumber String
    bio           String?
    isDeleted     Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    user User @relation(fields: [email], references: [email])

    @@map("admins")
}

model Seller {
    id            String   @id @default(uuid())
    name          String
    email         String   @unique
    storeName     String
    storeDescription String?
    profilePhoto  String?
    contactNumber String
    address       String?
    bio           String?
    isDeleted     Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    user     User      @relation(fields: [email], references: [email])
    products Product[]

    @@map("sellers")
}

model Customer {
    id            String   @id @default(uuid())
    name          String
    email         String   @unique
    profilePhoto  String?
    contactNumber String?
    address       String?
    bio           String?
    isDeleted     Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    user     User          @relation(fields: [email], references: [email])
    orders   Order[]
    cart     Cart?
    reviews  Review[]
    wishlist Wishlist?

    @@map("customers")
}
